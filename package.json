{
  "name": "anysub",
  "private": true,
  "version": "0.15.0",
  "type": "module",
  "license": "MIT",
  "description": "Japanese-immersion subtitles for any HTML5 video: per-kanji furigana, one-click Jimaku subtitles with auto next-episode, semantic CC formatting. Userscript.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.js",
    "build:readings": "curl -sL https://www.edrdg.org/kanjidic/kanjidic2.xml.gz | gunzip | node scripts/build-readings.mjs /dev/stdin > src/kanji-readings.js"
  },
  "devDependencies": {
    "vite": "^8.1.3",
    "vite-plugin-monkey": "^8.0.6"
  }
}
